POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=postgres
POSTGRES_PORT=18432

REDIS_PASSWORD=<your-redis-password>
REDIS_PORT=18379
REDIS_ENABLED=true
CACHE_TTL=300

MAIN_SERVER_PORT=18000
VNA_API_KEY=<your-vna-api-key>
BIDS_SERVER_API_KEY=<your-bids-server-api-key>

DICOM_SERVER_USER=<your-orthanc-user>
DICOM_SERVER_PASSWORD=<your-orthanc-password>
ORTHANC_DICOM_PORT=18242
ORTHANC_HTTP_PORT=18042

BIDS_SERVER_PORT=18080
BIDS_API_KEY=<your-bids-api-key>
ENABLE_BACKGROUND_WORKER=true
WORKER_POLL_INTERVAL=5

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

UX_PORT=13000
