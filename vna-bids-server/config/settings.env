# BIDS Server Configuration

# Database
DATABASE_URL=postgresql+asyncpg://bids:bids@postgres:5432/bidsserver
DATABASE_ECHO=false

# Storage
BIDS_ROOT=/bids_data
UPLOAD_TEMP_DIR=/tmp/bids_uploads

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=true

# Upload limits
MAX_UPLOAD_SIZE=10737418240  # 10GB
CHUNK_SIZE=10485760           # 10MB chunks for large file handling

# Hash algorithm
HASH_ALGORITHM=sha256
